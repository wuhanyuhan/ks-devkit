# {{.AppID}} — Keystone app（type: app，外部 MCP service）
# 由 `ks init {{.AppID}} --type=app --lang=go` 生成。
# 字段含义 / 最佳实践见 docs/decision-guide.md + docs/best-practices.md。
# VS Code 装 Red Hat YAML 扩展即按下行 schema 做校验 + 补全（ks init 已写 .vscode/settings.json）。
# yaml-language-server: $schema=.ks/manifest.schema.json
id: {{.AppID}}
name: {{.Name}}
version: 0.1.0
type: app
summary: {{.Summary}}
description: |
  {{.Summary}}——一句话说清这个 app 做什么、给谁用（写真话，别堆砌关键词）。
publisher: "{{.Publisher}}"
category: ""
tags: []

compatibility:
  keystone: ">=1.0.0"

# 鉴权 secure-by-default：keystone 出站签短期 JWT、app 入站用 SDK 校验。
# 本地裸跑：export KS_APP_AUTH_MODE=insecure；生产由平台注入 KEYSTONE_JWKS_URL。
auth:
  mode: keystone_jwks

runtime:
  mode: container
  # 容器内固定监听 8080（无需也不要声明端口字段）。
  health_check: /healthz
  health_check_url: "http://localhost:8080/mcp"
  image: "{{.AppID}}:0.1.0"
  resources:
    cpu: "0.5"
    memory: "256Mi"

# provides：你对外供给的能力。作者写【裸名】name，全局 canonical=<app_id>.<name> 由平台派生（别写前缀）。
provides:
  capabilities:
    - name: hello
      display_name: 示例能力
      description: 向调用方问好，演示一次最小能力调用。
      execution_mode: sync                 # sync | long_running | hybrid
      side_effect_level: none              # none | soft_reversible | hard_irreversible
      # decision_mode 省略：默认从 side_effect_level 派生（none→agent_autonomous）。仅敏感读等才覆盖。
      backend:
        kind: mcp_tool                     # mcp_tool（复用/生成 MCP tool）| http_endpoint
        tool_name: hello
      timeout_ms: 60000                    # 100..600000；留空=平台默认
      input_schema:
        type: object
        properties:
          name:
            type: string
            description: 要问好的对象
      output_schema:
        type: object
        properties:
          message:
            type: string

# requires：你依赖的他人能力。写【全名】canonical_name（不派生，与 provides 裸名不对称）。
# requires:
#   capabilities:
#     - canonical_name: other-app.some_capability
#       mode: required          # required | recommended | optional
#       reason: 说明为何依赖这个能力

permissions:
  # 最小权限：只声明你实际用到的维度（none=不申请）。filesystem/user_context 是高风险维度
  # （ks test 会重点标注），用到再加（如 filesystem.level: read_scoped）。
  # 注：网络/文件运行时 egress 沙箱是命名 Phase；当前 = 声明 + admin 安装期透明审查，别以为填了就被沙箱。
  network:
    level: none        # none | restricted | unrestricted
  llm:
    level: none        # none | host_proxy | self_managed
