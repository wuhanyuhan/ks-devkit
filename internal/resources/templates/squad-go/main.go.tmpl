package main

import (
	"github.com/wuhanyuhan/ks-devkit/sdk/go/ksapp"
)

func main() {
	// WithKeystoneAuth：secure-by-default 入站校验。WithManifest：读 provides 做四象限 wiring。
	app := ksapp.New("{{.AppID}}",
		ksapp.WithManifest("manifest.yaml"),
		ksapp.WithKeystoneAuth(),
		ksapp.WithVersion("0.1.0"),
	)

	// handle_request 是团队【前门能力】（裸名，与 manifest provides[].name 一致）。
	// 你的 LLM 负责人在 handler 内编排专家、派活、汇总——这部分是 squad 进程的自有逻辑。
	app.RegisterCapability("handle_request",
		func(ctx ksapp.CapabilityContext, args map[string]any) (any, error) {
			request, _ := args["request"].(string)
			// long_running：用 ctx.Progress(...) 上报进度；调下游透传 ctx.Context()。
			return map[string]any{"result": "已受理：" + request}, nil
		},
	)

	app.Run()
}
