  "show_when": [
    {
      "name": "simple_equality",
      "description": "字段等值条件：backend == 'github'",
      "dsl": "backend == 'github'",
      "context": { "field_under_if": "github_token" },
      "expected_json_schema": {
        "if": { "properties": { "backend": { "const": "github" } } },
        "then": { "required": ["github_token"] },
        "else": { "properties": { "github_token": false } }
      }
    },
    {
      "name": "simple_inequality",
      "description": "字段不等条件：type != 'github'",
      "dsl": "type != 'github'",
      "context": { "field_under_if": "base_url" },
      "expected_json_schema": {
        "if": { "properties": { "type": { "not": { "const": "github" } } } },
        "then": { "required": ["base_url"] },
        "else": { "properties": { "base_url": false } }
      }
    },
    {
      "name": "simple_in_list",
      "description": "集合包含条件：region in ['cn','us','eu']",
      "dsl": "region in ['cn','us','eu']",
      "context": { "field_under_if": "icp_number" },
      "expected_json_schema": {
        "if": { "properties": { "region": { "enum": ["cn", "us", "eu"] } } },
        "then": { "required": ["icp_number"] },
        "else": { "properties": { "icp_number": false } }
      }
    },
    {
      "name": "and_two_conditions",
      "description": "AND 组合：backend == 'github' && enabled == true",
      "dsl": "backend == 'github' && enabled == true",
      "context": { "field_under_if": "github_token" },
      "expected_json_schema": {
        "if": {
          "allOf": [
            { "properties": { "backend": { "const": "github" } } },
            { "properties": { "enabled": { "const": true } } }
          ]
        },
        "then": { "required": ["github_token"] },
        "else": { "properties": { "github_token": false } }
      }
    },
    {
      "name": "or_two_conditions",
      "description": "OR 组合：region == 'cn' || region == 'us'",
      "dsl": "region == 'cn' || region == 'us'",
      "context": { "field_under_if": "locale" },
      "expected_json_schema": {
        "if": {
          "anyOf": [
            { "properties": { "region": { "const": "cn" } } },
            { "properties": { "region": { "const": "us" } } }
          ]
        },
        "then": { "required": ["locale"] },
        "else": { "properties": { "locale": false } }
      }
    },
    {
      "name": "and_or_mixed_precedence",
      "description": "&& 优先级高于 ||：a == 'x' && b == 'y' || c == 'z' 等价 (a&&b)||c",
      "dsl": "a == 'x' && b == 'y' || c == 'z'",
      "context": { "field_under_if": "target_field" },
      "expected_json_schema": {
        "if": {
          "anyOf": [
            {
              "allOf": [
                { "properties": { "a": { "const": "x" } } },
                { "properties": { "b": { "const": "y" } } }
              ]
            },
            { "properties": { "c": { "const": "z" } } }
          ]
        },
        "then": { "required": ["target_field"] },
        "else": { "properties": { "target_field": false } }
      }
    },
    {
      "name": "number_literal",
      "description": "数字字面量：max_retries == 3",
      "dsl": "max_retries == 3",
      "context": { "field_under_if": "retry_delay_ms" },
      "expected_json_schema": {
        "if": { "properties": { "max_retries": { "const": 3 } } },
        "then": { "required": ["retry_delay_ms"] },
        "else": { "properties": { "retry_delay_ms": false } }
      }
    },
    {
      "name": "boolean_literal",
      "description": "布尔字面量：enabled == true",
      "dsl": "enabled == true",
      "context": { "field_under_if": "api_key" },
      "expected_json_schema": {
        "if": { "properties": { "enabled": { "const": true } } },
        "then": { "required": ["api_key"] },
        "else": { "properties": { "api_key": false } }
      }
    },
    {
      "name": "null_literal",
      "description": "null 字面量：proxy == null",
      "dsl": "proxy == null",
      "context": { "field_under_if": "direct_url" },
      "expected_json_schema": {
        "if": { "properties": { "proxy": { "const": null } } },
        "then": { "required": ["direct_url"] },
        "else": { "properties": { "direct_url": false } }
      }
    },
    {
      "name": "string_with_hyphens",
      "description": "含连字符的字符串值：backend == 'github-enterprise'",
      "dsl": "backend == 'github-enterprise'",
      "context": { "field_under_if": "enterprise_token" },
      "expected_json_schema": {
        "if": { "properties": { "backend": { "const": "github-enterprise" } } },
        "then": { "required": ["enterprise_token"] },
        "else": { "properties": { "enterprise_token": false } }
      }
    },
    {
      "name": "field_with_underscore",
      "description": "含下划线的字段名：config_mode == 'advanced'",
      "dsl": "config_mode == 'advanced'",
      "context": { "field_under_if": "advanced_options" },
      "expected_json_schema": {
        "if": { "properties": { "config_mode": { "const": "advanced" } } },
        "then": { "required": ["advanced_options"] },
        "else": { "properties": { "advanced_options": false } }
      }
    },
    {
      "name": "array_item_show_when",
      "description": "数组 item 内 show_when：type != 'github'（Spec A §3.4 数组场景）",
      "dsl": "type != 'github'",
      "context": {
        "field_under_if": "base_url",
        "array_context": true,
        "array_field": "backends"
      },
      "expected_json_schema": {
        "type": "array",
        "items": {
          "type": "object",
          "allOf": [
            {
              "if": { "properties": { "type": { "not": { "const": "github" } } } },
              "then": { "required": ["base_url"] },
              "else": { "properties": { "base_url": false } }
            }
          ]
        }
      }
    },
    {
      "name": "reject_parenthesis",
      "description": "拒绝：括号嵌套 (a || b) && c（MVP 不支持括号）",
      "dsl": "(a || b) && c",
      "should_reject": true,
      "reject_reason": "parenthesis_not_supported"
    },
    {
      "name": "reject_cross_level",
      "description": "拒绝：跨 level 字段引用 parent.field == 'x'",
      "dsl": "parent.field == 'x'",
      "should_reject": true,
      "reject_reason": "cross_level_reference_not_supported"
    },
    {
      "name": "reject_arithmetic",
      "description": "拒绝：算术运算 x + 1 == 2",
      "dsl": "x + 1 == 2",
      "should_reject": true,
      "reject_reason": "arithmetic_not_supported"
    }
  ],
