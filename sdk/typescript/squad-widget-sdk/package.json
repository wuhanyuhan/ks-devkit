{
  "name": "@wuhanyuhan/squad-widget-sdk",
  "version": "0.1.0",
  "description": "Squad-side widget SDK for keystone widgets-protocol-v1 (iframe runtime)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "happy-dom": "^20.8.9",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wuhanyuhan/ks-devkit.git",
    "directory": "sdk/typescript/squad-widget-sdk"
  },
  "license": "MIT",
  "keywords": ["keystone", "widget", "mcp", "iframe", "sdk"]
}
